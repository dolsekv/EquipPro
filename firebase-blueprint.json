{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A piece of professional equipment",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "nameAr": { "type": "string" },
        "description": { "type": "string" },
        "descriptionAr": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "categoryAr": { "type": "string" },
        "image": { "type": "string" },
        "rating": { "type": "number" },
        "reviews": { "type": "integer" },
        "brand": { "type": "string" },
        "stock": { "type": "integer" },
        "specs": { "type": "object" }
      },
      "required": ["name", "price", "category"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "shippingAddress": { "type": "object" }
      },
      "required": ["userId", "items", "total", "status"]
    },
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "wishlist": { "type": "array" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/products": { "schema": "Product", "description": "Collection of products" },
    "/orders": { "schema": "Order", "description": "Collection of orders" },
    "/users": { "schema": "User", "description": "User profiles" }
  }
}
